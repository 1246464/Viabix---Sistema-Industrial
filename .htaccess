# ======================================================
# Configuração Apache - Sistema Viabix
# PHP-FPM compatible configuration
# ======================================================

DirectoryIndex index.html index.php

# Ativar rewrite engine
RewriteEngine On

# Bloquear listagem de diretórios
Options -Indexes

# Bloquear acesso a arquivos sensíveis
<FilesMatch "\.(htaccess|htpasswd|ini|log|sh|sql|bak|config|env)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# ======================================================
# Redirecionamentos e regras de reescrita
# ======================================================

# NÃO reescrever pasta /api
RewriteCond %{REQUEST_URI} ^/api/ [OR]
# NÃO reescrever arquivos reais
RewriteCond %{REQUEST_FILENAME} -f [OR]
# NÃO reescrever diretórios reais
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Reescrever APENAS requisições sem extensão para index.html (SPA)
# Ignora completamente .php, .html, .css, .js, etc
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !\.php$ [NC]
RewriteCond %{REQUEST_URI} !\.html$ [NC]
RewriteCond %{REQUEST_URI} !\.js$ [NC]
RewriteCond %{REQUEST_URI} !\.css$ [NC]
RewriteCond %{REQUEST_URI} !\.json$ [NC]
RewriteCond %{REQUEST_URI} !\.png$ [NC]
RewriteCond %{REQUEST_URI} !\.jpg$ [NC]
RewriteCond %{REQUEST_URI} !\.gif$ [NC]
RewriteCond %{REQUEST_URI} !\.svg$ [NC]
RewriteCond %{REQUEST_URI} !\.woff$ [NC]
RewriteCond %{REQUEST_URI} !\.woff2$ [NC]
RewriteCond %{REQUEST_URI} !\.ttf$ [NC]
RewriteCond %{REQUEST_URI} !^/\.
RewriteRule ^(.*)$ index.html [L]