# ======================================================
# Configuração Apache - Sistema Viabix
# PHP-FPM compatible configuration
# ======================================================

DirectoryIndex index.html index.php

# Ativar rewrite engine
RewriteEngine On

# Bloquear listagem de diretórios
Options -Indexes

# Bloquear acesso a arquivos sensíveis
<FilesMatch "\.(htaccess|htpasswd|ini|log|sh|sql|bak|config|env)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# ======================================================
# Redirecionamentos e regras de reescrita
# ======================================================

# NÃO reescrever pasta /api - deixar arquivos serem servidos diretamente
RewriteCond %{REQUEST_FILENAME} ^.*/api/ [OR]
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Exceções explícitas para arquivos HTML que devem ser acessíveis diretamente
RewriteRule ^(dashboard_viabilidade|admin_saas|billing|login|signup|anvi|index|test_module_3_demo)\.html$ - [L]

# Página inicial
RewriteRule ^$ index.html [L]

# Reescrever para index.html se não é arquivo ou diretório ("SPA router") 
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [QSA,L]