# ======================================================
# Configuração Apache - Sistema Viabix
# PHP-FPM compatible configuration
# ======================================================

DirectoryIndex index.html index.php

# Ativar rewrite engine
RewriteEngine On

# Bloquear listagem de diretórios
Options -Indexes

# Bloquear acesso a arquivos sensíveis
<FilesMatch "\.(htaccess|htpasswd|ini|log|sh|sql|bak|config|env)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# ======================================================
# Redirecionamentos e regras de reescrita
# ======================================================

# NÃO reescrever pasta /api - deixar arquivos serem servidos diretamente
RewriteCond %{REQUEST_FILENAME} ^.*/api/ [OR]
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Página inicial - ANTES de redirecionar outras requisições
RewriteRule ^/?$ index.html [L]

# Reescrever rotas SPA (qualquer outra coisa) para index.html
# MAS não reescrever se:
#  - É um arquivo real (-f)
#  - É um diretório real (-d)
#  - É um arquivo com extensão conhecida (.php, .html, .css, .js, etc)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !\.php$ [NC]
RewriteCond %{REQUEST_FILENAME} !\.html$ [NC]
RewriteCond %{REQUEST_FILENAME} !\.js$ [NC]
RewriteCond %{REQUEST_FILENAME} !\.css$ [NC]
RewriteCond %{REQUEST_FILENAME} !\.json$ [NC]
RewriteCond %{REQUEST_FILENAME} !\.png$ [NC]
RewriteCond %{REQUEST_FILENAME} !\.jpg$ [NC]
RewriteCond %{REQUEST_FILENAME} !\.jpeg$ [NC]
RewriteCond %{REQUEST_FILENAME} !\.gif$ [NC]
RewriteCond %{REQUEST_FILENAME} !\.svg$ [NC]
RewriteCond %{REQUEST_FILENAME} !\.woff$ [NC]
RewriteCond %{REQUEST_FILENAME} !\.woff2$ [NC]
RewriteCond %{REQUEST_FILENAME} !\.ttf$ [NC]
RewriteRule ^ index.html [QSA,L]