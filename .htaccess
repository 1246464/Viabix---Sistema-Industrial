# ======================================================
# Configuração Apache - Sistema Viabix
# PHP-FPM compatible configuration
# ======================================================

DirectoryIndex index.html index.php

# Ativar rewrite engine
RewriteEngine On

# Bloquear listagem de diretórios
Options -Indexes

# Bloquear acesso a arquivos sensíveis
<FilesMatch "\.(htaccess|htpasswd|ini|log|sh|sql|bak|config|env)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# ======================================================
# Redirecionamentos e regras de reescrita
# ======================================================

# IMPORTANTE: NÃO REESCREVER nenhum arquivo físico
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# IMPORTANTE: NÃO REESCREVER nenhum diretório físico
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# IMPORTANTE: NÃO REESCREVER a pasta /api
RewriteCond %{REQUEST_URI} ^/api(/|$)
RewriteRule ^ - [L]

# Reescrever apenas requisições sem caminho para index.html
RewriteRule ^/?$ index.html [L]

# Reescrever APENAS requisições SPA (sem extensão, não existem como arquivo, não são diretório, não são API)
RewriteRule ^ index.html [L]