[Unit]
Description=Viabix background worker example
After=network.target mariadb.service

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/viabix
ExecStart=/usr/bin/php /var/www/viabix/api/diagnostico.php
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target