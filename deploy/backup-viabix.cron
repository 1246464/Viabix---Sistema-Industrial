SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

# Backup diário às 02:15
15 2 * * * root APP_DIR=/var/www/viabix BACKUP_DIR=/var/backups/viabix /usr/local/bin/backup-viabix.sh >> /var/log/viabix_backup.log 2>&1

# Healthcheck gravado em log a cada 5 minutos
*/5 * * * * root curl -fsS https://app.seudominio.com/api/healthcheck.php >> /var/log/viabix_healthcheck.log 2>&1