APP_ENV=production
APP_DEBUG=false

DB_HOST=127.0.0.1
DB_NAME=viabix_db
DB_USER=viabix_user
DB_PASS=troque-esta-senha
DB_CHARSET=utf8mb4

SESSION_NAME=viabix_session
SESSION_LIFETIME=28800
SESSION_SECURE=true
SESSION_SAMESITE=Strict

VIABIX_BILLING_PROVIDER=asaas
VIABIX_ASAAS_ENV=production
VIABIX_ASAAS_API_KEY=troque-sua-chave
VIABIX_ASAAS_WEBHOOK_TOKEN=troque-seu-token

# Monitoring & Error Tracking
SENTRY_DSN=https://seu-public-key@sentry.io/seu-project-id
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=1.0.0

# CORS Configuration (comma-separated origins)
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,http://localhost:3000

# Rate Limiting Configuration
# Login protection: max attempts per time window  
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW=300

# Signup protection: max attempts per time window
RATE_LIMIT_SIGNUP_MAX=3
RATE_LIMIT_SIGNUP_WINDOW=300

# API throttling: max requests per user per time window
RATE_LIMIT_API_MAX=100
RATE_LIMIT_API_WINDOW=60

# Email Configuration
# Provider options: smtp, sendgrid, mailgun
MAIL_PROVIDER=smtp

# SMTP Configuration
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME=Viabix
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=your-username
MAIL_PASSWORD=your-password
MAIL_ENCRYPTION=tls

# SendGrid Configuration (if MAIL_PROVIDER=sendgrid)
MAIL_SENDGRID_API_KEY=

# Mailgun Configuration (if MAIL_PROVIDER=mailgun)
MAIL_MAILGUN_API_KEY=
MAIL_MAILGUN_DOMAIN=

# Application URLs (for email links)
APP_URL=https://yourdomain.com

# Two-Factor Authentication (2FA)
# Enable/disable 2FA requirement
TWO_FACTOR_ENABLED=true

# 2FA configuration
TWO_FACTOR_OPTIONAL=false          # false = required, true = optional
TWO_FACTOR_METHOD=totp             # Default method: totp, email, or sms
TWO_FACTOR_EMAIL_EXPIRY=600         # Email OTP expiry in seconds (default: 10 min)
TWO_FACTOR_SESSION_EXPIRY=600       # Partial auth session expiry (default: 10 min)
TWO_FACTOR_QR_PROVIDER=qrserver     # QR code provider (qrserver or google)
TWO_FACTOR_APP_NAME=Viabix          # App name shown in authenticator

DB_OLD_NAME=fanavid_db