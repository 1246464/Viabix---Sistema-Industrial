APP_ENV=staging
APP_DEBUG=false
APP_URL=https://homolog.viabix.com.br

DB_HOST=127.0.0.1
DB_NAME=viabix_staging
DB_USER=viabix_staging_user
DB_PASS=troque-esta-senha
DB_CHARSET=utf8mb4
DB_PORT=3306

SESSION_NAME=viabix_staging_session
SESSION_LIFETIME=28800
SESSION_SECURE=true
SESSION_SAMESITE=Strict

JWT_SECRET=troque-por-chave-gerada-openssl-rand-hex-32

REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=2

VIABIX_BILLING_PROVIDER=manual
VIABIX_ASAAS_ENV=sandbox
VIABIX_ASAAS_API_KEY=
VIABIX_ASAAS_WEBHOOK_TOKEN=
WEBHOOK_SECRET=
WEBHOOK_SECRET_ASAAS=

SENTRY_DSN=
SENTRY_ENVIRONMENT=staging
SENTRY_RELEASE=staging

CORS_ALLOWED_ORIGINS=https://homolog.viabix.com.br

RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW=300
RATE_LIMIT_SIGNUP_MAX=3
RATE_LIMIT_SIGNUP_WINDOW=300
RATE_LIMIT_API_MAX=100
